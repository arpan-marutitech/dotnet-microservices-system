{
  "ConnectionStrings": {
    "DefaultConnection": "Server=sqldb;Database=DotNetLearning_Order;User Id=sa;Password=Your_password123;TrustServerCertificate=True;MultipleActiveResultSets=true",
    "ElasticsearchNodes": [
      "http://elasticsearch:9200"
    ]
  },

  "Jwt": {
    "Key": "Arpan@123_SuperSecureJWTKey_2026_ProductionReady",
    "Issuer": "OrderAPI",
    "Audience": "OrderAPIUsers",
    "ExpiryMinutes": 120
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    },
    "Elasticsearch": {
      "Enabled": true,
      "NodeUri": "http://elasticsearch:9200",
      "Username": "elastic",
      "Password": "elastic123",
      "IndexFormat": "logs-orderservice-{0:yyyy.MM.dd}",
      "BufferFile": null,
      "BufferFileSizeLimitMb": 50,
      "BufferRetention": 30,
      "MinimumLevel": "Information",
      "AutoRegisterTemplate": true,
      "NumberOfShards": 1,
      "NumberOfReplicas": 0
    },
    "FileLogging": {
      "Enabled": true,
      "Path": "logs/orderservice-{Date}.txt",
      "RetainedFileCount": 7,
      "RollingInterval": "Day"
    }
  },

  "CorrelationId": {
    "Header": "X-Correlation-Id"
  },

  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "10s",
        "Limit": 5
      }
    ]
  },

  "ServiceMetadata": {
    "ServiceName": "OrderService",
    "ServiceVersion": "1.0.0",
    "Environment": "Development"
  }
}
