{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Elasticsearch": {
      "Enabled": true,
      "NodeUri": "http://elasticsearch:9200",
      "Username": "elastic",
      "Password": "elastic123",
      "IndexFormat": "logs-apigateway-{0:yyyy.MM.dd}",
      "BufferFile": null,
      "BufferFileSizeLimitMb": 50,
      "BufferRetention": 30,
      "MinimumLevel": "Information",
      "AutoRegisterTemplate": true,
      "NumberOfShards": 1,
      "NumberOfReplicas": 0
    },
    "FileLogging": {
      "Enabled": true,
      "Path": "logs/apigateway-{Date}.txt",
      "RetainedFileCount": 7,
      "RollingInterval": "Day"
    }
  },

  "CorrelationId": {
    "Header": "X-Correlation-Id"
  },

  "ServiceMetadata": {
    "ServiceName": "ApiGateway",
    "ServiceVersion": "1.0.0",
    "Environment": "Development"
  }
}
